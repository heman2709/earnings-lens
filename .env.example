# Copy this file to .env and fill in your keys
# cp .env.example .env

# In earnings-lens/.env

# OpenAI API key (required)
OPENAI_API_KEY=your_openai_api_key_here

# LangChain + LangSmith (same API key is usually fine for both)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ct2-assignment

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here

LANGSMITH_ENDPOINT=your_langsmith_endpoint_here
LANGSMITH_PROJECT=your_langsmith_project_here
